# ============================================================
# Tove Ads 2.0 环境配置模板
# 复制为 .env 并填真实值。.env 绝不进 git。
# ============================================================

# ── 数据库（PostgreSQL）──
# toveads_app = RLS 受限角色（日常 CRUD）；toveads_super = BYPASSRLS 角色（超管操作/迁移）
# 先跑 db/init.sql 建角色+库，再填密码
DATABASE_URL=postgresql+psycopg2://toveads_app:CHANGE_ME@127.0.0.1:5432/toveads
DATABASE_SUPER_URL=postgresql+psycopg2://toveads_super:CHANGE_ME@127.0.0.1:5432/toveads

# ── JWT 认证 ──
JWT_SECRET=CHANGE_ME_TO_RANDOM_LONG_STRING
JWT_ALG=HS256
JWT_EXPIRE_MIN=10080
JWT_REFRESH_EXPIRE_DAYS=7

# ── 环境 ──
APP_ENV=production

# ── FB 凭证加密（Fernet 主密钥，生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）──
FB_CRED_KEY=CHANGE_ME_FERNET_KEY

# ── 公网 URL（OAuth 回调、CF Worker URL 拼接用）──
PUBLIC_BASE_URL=https://api.tovaads.com

# ── Cloudflare（落地页部署 + DNS 管理）──
CF_API_TOKEN=
CF_ACCOUNT_ID=

# ── AI 配置（OpenAI 兼容接口，默认 DeepSeek）──
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat

# ============================================================
# 前端配置（frontend/.env，可选）
# ============================================================
# VITE_API_BASE=https://api.tovaads.com
