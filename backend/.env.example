# Tove Ads 后端配置（复制为 .env 并填真实值，.env 不进 git）
DATABASE_URL=postgresql+psycopg2://toveads_app:CHANGE_ME@127.0.0.1:5432/toveads
DATABASE_SUPER_URL=postgresql+psycopg2://toveads_super:CHANGE_ME@127.0.0.1:5432/toveads
JWT_SECRET=CHANGE_ME_TO_RANDOM_LONG_STRING
JWT_ALG=HS256
JWT_EXPIRE_MIN=60
JWT_REFRESH_EXPIRE_DAYS=7
APP_ENV=development
# FB 凭证加密主密钥（Fernet，生产从 secret manager 读）
FB_CRED_KEY=CHANGE_ME_FERNET_KEY
