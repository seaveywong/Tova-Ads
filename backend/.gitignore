# Python 字节码 / 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
.venv/
env/
ENV/

# 环境变量（.env 含真实密钥/DB URL/SECRET，绝不提交；.env.example 是模板，保留提交）
.env
.env.local
.env.*.local

# 测试 / 类型 / lint 缓存
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# 本地测试数据库
*.sqlite3
*.db

# 日志
*.log
logs/

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp
